//@version=6
strategy("AAPL 1D Sharpe1 Strategy", overlay=true, pyramiding=0, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.1)

// --- 設定與變數 ---
len5    = 5
len10   = 10
len20   = 20
len60   = 60
len200  = 200

rsiLength      = 14
rsiOversold    = 30
rsiOverbought  = 70

zlsma_length   = 20

// --- 指標計算 ---
ema5  = ta.ema(close, len5)
ema10 = ta.ema(close, len10)
rsi   = ta.rsi(close, rsiLength)

// 零滯後移動平均線 (ZLSMA)
zlsma = 2 * ta.sma(close, zlsma_length) - ta.sma(ta.sma(close, zlsma_length), zlsma_length)

// --- 訊號條件 ---
ema5CrossOver10    = ta.crossover(ema5, ema10)
rsiExitOverbought  = ta.crossunder(rsi, rsiOverbought)
priceBreakoutZlsma = ta.crossover(close, zlsma)
priceBreakdownZlsma = ta.crossunder(close, zlsma)

// 進場與出場邏輯
entryCondition = ema5CrossOver10 and priceBreakoutZlsma
exitCondition  = rsiExitOverbought and priceBreakdownZlsma

// --- 執行策略 ---
if exitCondition and strategy.position_size > 0
    strategy.close("Long", comment="Exit")

if entryCondition and strategy.position_size <= 0 and not exitCondition
    strategy.entry("Long", strategy.long, comment="Entry")

